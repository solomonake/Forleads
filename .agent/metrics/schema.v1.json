{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Forleads agent task scorecard",
  "type": "object",
  "required": [
    "schemaVersion",
    "recordedAt",
    "agent",
    "model",
    "taskId",
    "risk",
    "outcome",
    "mandatoryGatesPassed",
    "mandatoryGatesTotal",
    "escapedDefects",
    "securityFindings",
    "humanInterventions",
    "handoffRecoveryMinutes"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "recordedAt": { "type": "string", "format": "date-time" },
    "agent": { "type": "string" },
    "model": { "type": "string" },
    "taskId": { "type": "string" },
    "risk": { "enum": ["low", "medium", "high", "critical"] },
    "outcome": { "enum": ["success", "partial", "failed", "blocked"] },
    "branch": { "type": "string" },
    "commit": { "type": "string" },
    "elapsedMinutes": { "type": "number", "minimum": 0 },
    "humanInterventions": { "type": "integer", "minimum": 0 },
    "secretOrSpendApprovals": { "type": "integer", "minimum": 0 },
    "commandCount": { "type": "integer", "minimum": 0 },
    "mandatoryGatesPassed": { "type": "integer", "minimum": 0 },
    "mandatoryGatesTotal": { "type": "integer", "minimum": 0 },
    "escapedDefects": { "type": "integer", "minimum": 0 },
    "securityFindings": { "type": "integer", "minimum": 0 },
    "productionIncidents": { "type": "integer", "minimum": 0 },
    "handoffRecoveryMinutes": { "type": "number", "minimum": 0 },
    "estimatedCostUsd": { "type": "number", "minimum": 0 },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}

