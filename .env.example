# ============================================================================
# Forleads — Environment configuration
# Copy to `.env.local` and fill in. Local development runs in mock mode with
# zero credentials. In production, omitted switches infer safe live defaults:
# Nominatim geocoding, OSM property facts, Supabase when configured, Mapillary
# when configured, and Claude when configured. Set a switch explicitly to
# override that inference.
# Production mock connector writes are disabled by default. The escape hatch
# below is for disposable previews only and must never be set on the main
# production deployment.
# Secrets are SERVER-ONLY. Never expose anything but NEXT_PUBLIC_* to the client.
# ============================================================================

# ---- Provider mode switches -------------------------------------------------
# These explicit values preserve mock-first local development.
FORLEADS_AGENT_MODE=mock              # Claude reasoning: mock | live
FORLEADS_PROPERTY_PROVIDER=osm-mock   # osm-mock | osm | attom | (per-market)
FORLEADS_IMAGERY_PROVIDER=mock        # mock | mapillary
FORLEADS_GEOCODER=mock                # mock | nominatim | photon-nominatim
FORLEADS_RISK_PROVIDER=mock           # mock | fema-nfhl
FORLEADS_PERSIST=memory               # memory (in-process) | supabase
FORLEADS_ALLOW_PRODUCTION_MOCKS=0

# ---- Claude (Agent brain) ---------------------------------------------------
# Used by Dispatcher / Notes classifier / Composer / Compliance / Reducer.
ANTHROPIC_API_KEY=
FORLEADS_CLAUDE_MODEL=claude-sonnet-4-6

# ---- Vision + bulk (cheap classification / photo understanding) -------------
GEMINI_API_KEY=
GROQ_API_KEY=

# ---- Supabase / Postgres (persistence, auth, RLS, pgvector) -----------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=            # SERVER ONLY — never ship to client
DATABASE_URL=

# ---- Geocoding (self-hosted) ------------------------------------------------
PHOTON_URL=http://localhost:2322
NOMINATIM_URL=http://localhost:8080

# ---- Imagery ----------------------------------------------------------------
MAPILLARY_TOKEN=
ESRI_ATTRIBUTION="Imagery © Esri"

# ---- Embeddings (lead-scoped memory recall) ---------------------------------
# Server-only. When OLLAMA_URL is unreachable or unset, a deterministic hash
# embedder is used so the loop still runs (mock-first principle). The selected
# model must emit 1024-dim vectors to match the memories.embedding column.
OLLAMA_URL=http://localhost:11434
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_DIM=1024

# ============================================================================
# CONNECTORS — each flips from mock to real when its credentials are present.
# Connector mode is also viewable/forced in the Connector Hub UI.
# ============================================================================

# ---- Google Workspace (Gmail drafts + Calendar) -----------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must EXACTLY match an Authorized redirect URI in your Google OAuth client.
# Local:  http://localhost:3000/api/auth/google/callback
# Vercel: https://forleads.vercel.app/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# Minimal scopes: compose drafts only + calendar events.
GOOGLE_SCOPES=https://www.googleapis.com/auth/gmail.compose https://www.googleapis.com/auth/calendar.events

# ---- Microsoft 365 (Outlook + Calendar) -------------------------------------
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=http://localhost:3000/api/connectors/microsoft/callback

# ---- Follow Up Boss (CRM) ---------------------------------------------------
FOLLOWUPBOSS_API_KEY=
FOLLOWUPBOSS_BASE_URL=https://api.followupboss.com/v1

# ---- GoHighLevel (CRM / agencies) -------------------------------------------
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_BASE_URL=https://services.leadconnectorhq.com

# ---- Twilio (SMS — approved sends only) -------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---- Zapier / generic webhooks ----------------------------------------------
# Inbound: Forleads exposes /api/connectors/zapier/inbound (see Connector Hub).
ZAPIER_WEBHOOK_SECRET=

# ---- Auth / session --------------------------------------------------------
# Encrypts the login session cookie (which carries the user's Google tokens).
# Generate one: `openssl rand -hex 32`. REQUIRED in production.
SESSION_SECRET=
# Vercel Cron sends this as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=
# Founder-only metrics access. Email fallback is enough for v1; add FOUNDER_SUB
# after your first login if you want the tighter match.
FOUNDER_EMAIL=solomonriting@gmail.com
FOUNDER_SUB=
# Optional: a Google access token for server-to-server testing without OAuth.
GOOGLE_ACCESS_TOKEN=

# ---- Observability / quotas / onboarding -----------------------------------
SENTRY_DSN=
RATE_LIMIT_DAILY_QUOTA=5000
WELCOME_EMAIL_ENABLED=0

# ---- App ------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
FORLEADS_DEMO_AGENT_ID=00000000-0000-0000-0000-000000000001
